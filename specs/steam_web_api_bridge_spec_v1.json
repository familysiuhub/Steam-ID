{
  "name": "Steam_Web_API_Bridge_v1",
  "version": "1.0.0",
  "description": "Technical specification for bridging with the Steam Web API. Supports News, Player Summaries, and Achievement data.",
  "baseUrl": "https://api.steampowered.com/",
  "auth": {
    "type": "query_param",
    "paramName": "key",
    "source": "https://steamcommunity.com/dev/apikey"
  },
  "endpoints": [
    {
      "name": "GetNewsForApp",
      "path": "ISteamNews/GetNewsForApp/v2/",
      "method": "GET",
      "params": ["appid", "count", "maxlength", "enddate", "feeds"]
    },
    {
      "name": "GetPlayerSummaries",
      "path": "ISteamUser/GetPlayerSummaries/v0002/",
      "method": "GET",
      "params": ["steamids"]
    },
    {
      "name": "GetGlobalAchievementPercentagesForApp/v0002/",
      "method": "GET",
      "params": ["appid"]
    }
  ],
  "notes": "Always verify appid and steamid format (uint32/uint64). Response is typically JSON by default."
}
